# Agri-Logix USSD Simulator Configuration
# Copy this to .env and adjust as needed

# USSD server URL (for simulate.js and test.js)
USSD_URL=http://localhost:4000/ussd

# Default phone number for simulation
PHONE=+263771000001

# Africa's Talking API (for production)
AT_API_KEY=your_api_key_here
AT_USERNAME=sandbox
AT_SHORT_CODE=*123#
