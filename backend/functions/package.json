    "json2csv": "^6.0.0-alpha.2",
    "pdfkit": "^0.13.0",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.7",
    "firebase-functions-test": "^3.1.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.3.3"
  }
