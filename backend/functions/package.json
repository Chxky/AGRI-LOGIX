{
  "name": "agri-logix-backend",
  "description": "Cloud Functions for Agri-Logix SeedTracker MVP",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
